// ═══════════════ STATE + PERSISTENCE ════════════════════════
const LS = 'cq_v2';
function loadSave(){try{return JSON.parse(localStorage.getItem(LS))||{};}catch{return {};}}
function writeSave(){try{localStorage.setItem(LS,JSON.stringify({done:[...done],xp:totalXP,n:totalDone,streak,lastDate,lb:leaderboard,name:playerName}));}catch{}}

const sv = loadSave();
const done = new Set(sv.done||[]);
let totalXP = sv.xp||0, totalDone = sv.n||0, streak = sv.streak||0, lastDate = sv.lastDate||'';
let leaderboard = sv.lb||[{name:'Alice',xp:1200},{name:'Bob',xp:800},{name:'Carol',xp:640}];
let playerName = sv.name||'';
let curTrack=null, curChIdx=0, mobCurTab='lesson', curMode='python';
let prevScreen='home';
let sqlDB=null, pyReady=false;

function updateStreak(){
  const today=new Date().toDateString(),yest=new Date(Date.now()-86400000).toDateString();
  if(lastDate===today)return;
  streak = lastDate===yest ? streak+1 : 1;
  lastDate=today; writeSave();
}

const SQL_SEED=`CREATE TABLE IF NOT EXISTS users(id INTEGER PRIMARY KEY,name TEXT,email TEXT,city TEXT);CREATE TABLE IF NOT EXISTS products(id INTEGER PRIMARY KEY,name TEXT,price REAL,category TEXT);CREATE TABLE IF NOT EXISTS orders(id INTEGER PRIMARY KEY,user_id INTEGER,product_id INTEGER,quantity INTEGER,date TEXT);INSERT OR IGNORE INTO users VALUES(1,'Alice','a@e.com','Mumbai'),(2,'Bob','b@e.com','Delhi'),(3,'Carol','c@e.com','Mumbai'),(4,'Dave','d@e.com','Bangalore'),(5,'Eve','e@e.com','Pune'),(6,'Frank','f@e.com','Delhi');INSERT OR IGNORE INTO products VALUES(1,'Laptop',75000,'Electronics'),(2,'Phone',25000,'Electronics'),(3,'Headphones',3500,'Electronics'),(4,'Coffee Mug',350,'Kitchen'),(5,'Python Book',1200,'Books'),(6,'Chair',8500,'Furniture'),(7,'Desk',12000,'Furniture'),(8,'Notebook',150,'Stationery');INSERT OR IGNORE INTO orders VALUES(1,1,1,1,'2025-01-10'),(2,1,3,2,'2025-01-12'),(3,2,2,1,'2025-01-15'),(4,3,5,3,'2025-01-16'),(5,4,6,1,'2025-01-20'),(6,5,4,5,'2025-01-22'),(7,2,1,1,'2025-02-01'),(8,6,8,10,'2025-02-05'),(9,3,2,2,'2025-02-10'),(10,1,7,1,'2025-02-15');`;

// ═══════════════ LOADING ═════════════════════════════════════
let fp=0;
const fb=setInterval(()=>{fp=Math.min(fp+2,78);document.getElementById('ld-bar').style.width=fp+'%';},100);
function ldMsg(m){document.getElementById('ld-msg').textContent=m;}

async function initAll(){
  ldMsg('Loading Python…');
  Sk.configure({output:()=>{},read:x=>{
    if(Sk.builtinFiles&&Sk.builtinFiles.files[x]!==undefined)return Sk.builtinFiles.files[x];
    throw "File not found: '"+x+"'";
  }});
  pyReady=true;
  ldMsg('Loading SQL…');
  await initSqlJs({locateFile:f=>`https://cdn.jsdelivr.net/npm/sql.js@1.10.3/dist/${f}`})
    .then(S=>{sqlDB=new S.Database();sqlDB.run(SQL_SEED);})
    .catch(()=>{});
  updateStreak();
  clearInterval(fb);
  document.getElementById('ld-bar').style.width='100%';
  ldMsg('Ready!');
  await new Promise(r=>setTimeout(r,250));
  const ov=document.getElementById('loading');
  ov.classList.add('out');
  setTimeout(()=>ov.style.display='none',550);
  initApp();
}
document.addEventListener('DOMContentLoaded',initAll);

// ═══════════════ PYTHON (Skulpt) ═════════════════════════════
async function execPy(code){
  if(!pyReady)return{out:'',err:'Python not ready.'};
  return new Promise(res=>{
    let out='';
    Sk.configure({
      output:t=>{out+=t;},
      read:x=>{if(Sk.builtinFiles&&Sk.builtinFiles.files[x]!==undefined)return Sk.builtinFiles.files[x];throw"File not found: '"+x+"'";},
      inputfun:()=>Promise.resolve(''),
      __future__:Sk.python3
    });
    Sk.misceval.asyncToPromise(()=>Sk.importMainWithBody('<stdin>',false,code,true))
      .then(()=>res({out,err:null}))
      .catch(e=>{
        const msg=e.toString().replace(/^.*?Error:\s*/,'').replace(/\s+on line \d+/,'').trim();
        res({out,err:msg||String(e)});
      });
  });
}

// ═══════════════ SQL ═════════════════════════════════════════
function sqlQuery(sql){
  if(!sqlDB)return[];
  let last=[];
  for(const s of sql.split(';').map(x=>x.trim()).filter(Boolean)){
    const r=sqlDB.exec(s);
    if(r.length>0){const{columns:c,values:v}=r[0];last=v.map(row=>{const o={};c.forEach((k,i)=>o[k]=row[i]);return o;});}
    else last=[];
  }
  return last;
}
async function runSQL(){
  const code=G('sql-ed').value;
  sBtn('btn-run',true,'⏳');
  try{
    const rows=sqlQuery(code);
    const so=G('sql-out'),ss=G('sql-st');
    if(!rows.length){so.innerHTML='<span class="ook">✓ OK (no rows)</span>';ss.textContent='OK';ss.style.color='var(--ok)';}
    else{
      const cols=Object.keys(rows[0]);
      let h=`<table class="sql-tbl"><thead><tr>${cols.map(c=>`<th>${e(c)}</th>`).join('')}</tr></thead><tbody>`;
      rows.forEach(r=>{h+=`<tr>${cols.map(c=>`<td>${e(String(r[c]??''))}</td>`).join('')}</tr>`;});
      h+=`</tbody></table><div style="font-size:10px;color:var(--t3);margin-top:5px">${rows.length} row${rows.length!==1?'s':''}</div>`;
      so.innerHTML=h; ss.textContent=rows.length+' rows'; ss.style.color='var(--ok)';
    }
  }catch(ex){
    G('sql-out').innerHTML=`<span class="oerr">❌ ${e(ex.message||String(ex))}</span>`;
    G('sql-st').textContent='Error'; G('sql-st').style.color='var(--err)';
  }
  sBtn('btn-run',false,'▶ Run Query');
}

// ═══════════════ SYNTAX HIGHLIGHTING ════════════════════════
function hlPy(raw){
  let h=raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  h=h.replace(/(#[^\\n]*)/g,'<span class="hl-cm">$1</span>');
  h=h.replace(/('[^']*'|"[^"]*")/g,'<span class="hl-st">$1</span>');
  h=h.replace(/(#[^\n]*)/g,'<span class="hl-cm">$1</span>');
  h=h.replace(/\b(def|class|if|elif|else|for|while|return|import|from|in|not|and|or|is|True|False|None|pass|break|continue|try|except|finally|with|as|lambda|yield|global|nonlocal|del|raise|assert|self|super)\b/g,'<span class="hl-kw">$1</span>');
  h=h.replace(/\b(print|len|range|type|str|int|float|list|dict|set|tuple|bool|input|open|enumerate|zip|map|filter|sorted|sum|min|max|abs|round|hex|bin|chr|ord|repr|vars|dir|hasattr|getattr|setattr|isinstance|issubclass|staticmethod|classmethod|property)\b/g,'<span class="hl-bi">$1</span>');
  h=h.replace(/\b(\d+\.?\d*|\.\d+)\b/g,'<span class="hl-nm">$1</span>');
  return h;
}
function hlHTML(raw){
  let h=raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  h=h.replace(/(&lt;!--[\s\S]*?--&gt;)/g,'<span class="hl-cm">$1</span>');
  h=h.replace(/(&lt;\/?[\w.:-]+)((?:\s+[\w:-]+=(?:"[^"]*"|'[^']*'|[^\s>]*))*)\s*\/?&gt;/g,
    (m,tag,attrs)=>`<span class="hl-tag">${tag}</span>${attrs.replace(/([\w:-]+)=("[^"]*"|'[^']*')/g,'<span class="hl-attr">$1</span>=<span class="hl-val">$2</span>')}&gt;`);
  h=h.replace(/(&amp;[\w#]+;)/g,'<span class="hl-ent">$1</span>');
  return h;
}
function hlSQL(raw){
  let h=raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  h=h.replace(/('(?:[^'\\]|\\.)*')/g,'<span class="hl-sql-str">$1</span>');
  h=h.replace(/(--[^\n]*)/g,'<span class="hl-cm">$1</span>');
  h=h.replace(/\b(SELECT|FROM|WHERE|INSERT|INTO|VALUES|UPDATE|SET|DELETE|CREATE|TABLE|DROP|ALTER|ADD|COLUMN|INDEX|JOIN|LEFT|RIGHT|INNER|OUTER|ON|GROUP|BY|ORDER|HAVING|LIMIT|OFFSET|DISTINCT|AS|AND|OR|NOT|IN|LIKE|BETWEEN|IS|NULL|PRIMARY|KEY|IF|EXISTS|FOREIGN|REFERENCES|CASCADE|DEFAULT|CONSTRAINT|UNIQUE|CHECK)\b/gi,
    '<span class="hl-sql-kw">$&</span>');
  h=h.replace(/\b(COUNT|SUM|AVG|MIN|MAX|ROUND|COALESCE|IFNULL|LENGTH|UPPER|LOWER|SUBSTR|TRIM|DATE|NOW|STRFTIME)\b/gi,
    '<span class="hl-sql-fn">$&</span>');
  h=h.replace(/\b(\d+\.?\d*)\b/g,'<span class="hl-sql-nm">$1</span>');
  return h;
}
function applyHL(ta, hlEl, lnEl, hlFn){
  const v=ta.value;
  hlEl.innerHTML=hlFn(v)+'\n'; // trailing \n keeps heights in sync
  // sync scroll
  hlEl.scrollTop=ta.scrollTop; hlEl.scrollLeft=ta.scrollLeft;
  // line numbers
  const lines=v.split('\n').length;
  lnEl.textContent=Array.from({length:lines},(_,i)=>i+1).join('\n');
}
function syncPyHL(){applyHL(G('code-ed'),G('hl-py'),G('ln-py'),hlPy);}
function syncWebHL(){applyHL(G('web-ed'),G('hl-web'),G('web-lns'),hlHTML);}
function syncSqlHL(){applyHL(G('sql-ed'),G('hl-sql'),G('sql-lns'),hlSQL);}

// ═══════════════ APP INIT ════════════════════════════════════
function initApp(){
  renderHome();
  initEditors();
  initGit();
  updateChips();
  // Ask for name if new user
  if(!playerName&&totalDone===0){
    setTimeout(()=>{
      const n=prompt('Welcome to CodeQuest! What\'s your name?');
      if(n&&n.trim()){playerName=n.trim();writeSave();}
    },600);
  }
}

// ═══════════════ SCREENS ════════════════════════════════════
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  G(id).classList.add('active');
}
function goHome(){
  prevScreen='home';
  showScreen('home');
  G('back-btn').style.display='none';
  G('bc').textContent='Choose your adventure ⬇️';
  renderHome();
}
function goBack(){
  if(prevScreen==='track'&&curTrack){
    openTrack(curTrack.id);
  } else {
    goHome();
  }
}

// ═══════════════ HOME ════════════════════════════════════════
function renderHome(){
  const MAX=TRACKS.reduce((s,t)=>s+t.chapters.reduce((a,c)=>a+c.xp,0),0);
  const totalCh=TRACKS.reduce((s,t)=>s+t.chapters.length,0);
  G('stats-row').innerHTML=`
    <div class="stat-card"><div class="stat-n" style="color:var(--py)">${TRACKS.length}</div><div class="stat-l">Tracks</div></div>
    <div class="stat-card"><div class="stat-n" style="color:var(--ok)">${totalDone}/${totalCh}</div><div class="stat-l">Done</div></div>
    <div class="stat-card"><div class="stat-n" style="color:var(--js)">${totalXP}</div><div class="stat-l">XP</div></div>
    <div class="stat-card"><div class="stat-n" style="color:var(--git)">${streak}</div><div class="stat-l">Streak 🔥</div></div>
  `;
  // Continue banner
  const cw=G('cont-wrap');
  if(curTrack&&curChIdx>=0){
    const ch=curTrack.chapters[curChIdx];
    cw.innerHTML=`<div class="cont-card" onclick="openTrack('${curTrack.id}');setTimeout(()=>openChapter(${curChIdx}),80)">
      <div><div class="cont-label">Continue learning</div><div class="cont-title">${curTrack.icon} ${curTrack.name} › ${ch.icon} ${ch.title}</div></div>
      <div class="cont-arrow">→</div>
    </div>`;
  } else cw.innerHTML='';

  // Leaderboard
  renderLB();

  // Tracks grid
  G('tg').innerHTML=TRACKS.map(t=>{
    const td=t.chapters.filter(c=>done.has(c.id)).length;
    const pct=Math.round(td/t.chapters.length*100);
    return `<div class="tc" onclick="openTrack('${t.id}')" style="--c:${t.color}">
      <span class="tc-ico">${t.icon}</span>
      <div class="tc-name">${t.name}</div>
      <div class="tc-sub">${t.sub}</div>
      <div class="tc-pbar"><div class="tc-pfill" style="width:${pct}%"></div></div>
      <div class="tc-meta"><span>${td}/${t.chapters.length}</span><span class="tc-badge">${t.badge}</span></div>
    </div>`;
  }).join('');
}

function renderLB(){
  // Add current player to LB if they have XP
  if(playerName&&totalXP>0){
    const idx=leaderboard.findIndex(x=>x.name===playerName);
    if(idx>=0)leaderboard[idx].xp=totalXP;
    else leaderboard.push({name:playerName,xp:totalXP});
  }
  const sorted=[...leaderboard].sort((a,b)=>b.xp-a.xp).slice(0,5);
  const maxXP=sorted[0]?.xp||1;
  const ranks=['🥇','🥈','🥉','4','5'];
  const rankCls=['g1','g2','g3','',''];
  G('lb-wrap').innerHTML=`<div class="lb-card">
    <div class="lb-title">🏆 Leaderboard</div>
    ${sorted.map((p,i)=>`<div class="lb-row">
      <div class="lb-rank ${rankCls[i]}">${ranks[i]}</div>
      <div class="lb-name" style="${p.name===playerName?'color:var(--py)':''}">${e(p.name)}${p.name===playerName?' (you)':''}</div>
      <div class="lb-bar-wrap"><div class="lb-bar" style="width:${Math.round(p.xp/maxXP*100)}%"></div></div>
      <div class="lb-xp">${p.xp} XP</div>
    </div>`).join('')}
  </div>`;
}

// ═══════════════ TRACK SCREEN ════════════════════════════════
function openTrack(id){
  prevScreen='track';
  curTrack=TRACKS.find(t=>t.id===id);
  const t=curTrack;
  G('ti').textContent=t.icon; G('tn').textContent=t.name; G('ts').textContent=t.sub;
  const td=t.chapters.filter(c=>done.has(c.id)).length;
  const txp=t.chapters.filter(c=>done.has(c.id)).reduce((s,c)=>s+c.xp,0);
  const mx=t.chapters.reduce((s,c)=>s+c.xp,0);
  G('tb').style.cssText=`width:${td/t.chapters.length*100}%;background:${t.color}`;
  G('trk-stats').innerHTML=`Completed <b>${td}</b> of <b>${t.chapters.length}</b> chapters · <b>${txp}/${mx} XP</b>`;
  G('trk-hero').style.setProperty('--c',t.color);
  G('chl').innerHTML=t.chapters.map((ch,i)=>`
    <div class="ch-item ${ch.isProject?'ch-proj':''} ${done.has(ch.id)?'done':''}" onclick="openChapter(${i})" style="--c:${t.color}">
      <div class="ch-num">${ch.isProject?'🏆':i+1}</div>
      <div class="ch-info">
        <div class="ch-title">${ch.icon} ${ch.title}</div>
        <div class="ch-sub">${ch.sub}</div>
      </div>
      <div class="ch-right">
        <span class="ch-xp">+${ch.xp} XP</span>
        <span class="ch-star">⭐</span>
      </div>
    </div>`).join('');
  showScreen('trkscreen');
  G('back-btn').style.display='flex';
  G('bc').innerHTML=`${t.icon} <b>${t.name}</b>`;
}

// ═══════════════ CHAPTER / LESSON ════════════════════════════
function openChapter(idx){
  prevScreen='lesson';
  curChIdx=idx;
  const ch=curTrack.chapters[idx];
  curMode=curTrack.type;
  showScreen('lessonscreen');
  G('back-btn').style.display='flex';
  G('bc').innerHTML=`${curTrack.icon} ${curTrack.name} › <b>${ch.title}</b>`;
  // Set CSS var on lesson screen
  G('lessonscreen').style.setProperty('--c',curTrack.color);
  G('sb').style.setProperty('--c',curTrack.color);
  G('sb-name').textContent=curTrack.name;
  renderSb(); updateSbXP();
  setEdMode(curTrack.type,ch);
  const lh=buildLesson(ch,'d');
  G('lesson-pane').innerHTML=lh; G('lesson-pane').scrollTop=0;
  G('mob-lesson-panel').innerHTML=buildLesson(ch,'m');
  G('mob-lesson-panel').scrollTop=0;
  renderMobChs();
  if(isMob()) mTab('lesson');
  writeSave();
}

function setEdMode(type,ch){
  ['py-mode','web-mode','sql-mode','git-mode'].forEach(id=>G(id).style.display='none');
  G('btn-run').style.display=''; G('btn-check').style.display=''; G('btn-hint').style.display='';
  G('btn-run').textContent='▶ Run';
  if(type==='python'){
    G('py-mode').style.display='flex';
    G('ed-file').textContent='main.py';
    G('code-ed').value=ch.ch.start;
    syncPyHL(); setOut('od','▶ Run code to see output'); setSt('','');
  } else if(type==='web'){
    G('web-mode').style.display='flex';
    G('ed-file').textContent='index.html';
    G('web-ed').value=ch.ch.start;
    syncWebHL(); updatePreview();
    G('web-st').textContent='';
  } else if(type==='sql'){
    G('sql-mode').style.display='flex';
    G('ed-file').textContent='query.sql';
    G('sql-ed').value=ch.ch.start;
    syncSqlHL();
    G('sql-out').innerHTML='<span class="od">▶ Run query</span>'; G('sql-st').textContent='';
    G('btn-run').textContent='▶ Run Query';
  } else if(type==='concept'){
    G('git-mode').style.display='flex';
    G('ed-file').textContent='terminal';
    G('btn-run').style.display='none'; G('btn-check').style.display='none'; G('btn-hint').style.display='none';
    G('git-term').innerHTML='<div><span class="git-info">Git Simulator — type real git commands!</span></div>\n';
    G('git-inp').value='';
  }
}

function buildLesson(ch,sfx){
  const tc=curTrack.color, isDone=done.has(ch.id);
  const next=curChIdx+1<curTrack.chapters.length?curTrack.chapters[curChIdx+1]:null;
  return`<div class="ch-tag">${curTrack.icon} ${curTrack.name} · Ch ${curChIdx+1} · +${ch.xp} XP</div>
<h2 class="ch-h1">${ch.icon} ${ch.title}</h2>
<p class="ch-sub">${ch.sub}</p>
<div class="theory">${ch.theory}</div>
<div class="ex-block">
  <div class="ex-lbl">📋 Example — click to load</div>
  <pre class="ex-code" onclick="loadEx()">${e(ch.ex)}</pre>
  <button class="load-btn" onclick="loadEx()">▶ Load Example</button>
</div>
<div class="ch-box">
  <div class="ch-box-lbl">🎯 Challenge</div>
  <div class="ch-box-title">${ch.ch.title}</div>
  <div class="ch-box-desc">${ch.ch.desc}</div>
  <div class="exp-wrap">
    <div class="exp-lbl">Expected output</div>
    <pre class="exp-code">${e(ch.ch.exp)}</pre>
  </div>
</div>
<div class="done-banner ${isDone?'show':''}" id="db-${sfx}">🎉 <strong>Challenge complete!</strong> You earned <strong>+${ch.xp} XP</strong>!</div>
${next?`<button class="nxt-btn ${isDone?'show':''}" id="nb-${sfx}" onclick="openChapter(${curChIdx+1})">Next: ${next.icon} ${next.title} →</button>`:''}`;
}

function loadEx(){
  const ch=curTrack.chapters[curChIdx];
  if(curMode==='python'){G('code-ed').value=ch.ex;syncPyHL();}
  else if(curMode==='web'){G('web-ed').value=ch.ex;syncWebHL();updatePreview();}
  else if(curMode==='sql'){G('sql-ed').value=ch.ex;syncSqlHL();}
  setOut('od','Press ▶ Run'); setSt('','');
  if(isMob()) mTab('code');
}

// ═══════════════ RUN / CHECK / HINT ══════════════════════════
async function runCode(){
  if(curMode==='web'){updatePreview();return;}
  if(curMode==='sql'){await runSQL();return;}
  if(curMode==='concept')return;
  const code=G('code-ed').value;
  sBtn('btn-run',true,'⏳'); setOut('od','Running…'); setSt('','');
  const{out,err}=await execPy(code);
  if(err){setOut('oerr','❌ '+err);setSt('● Error','var(--err)');}
  else{setOut('ook',out||'(no output)');setSt('✓ OK','var(--ok)');}
  sBtn('btn-run',false,'▶ Run');
  if(isMob()) mTab('code');
}

async function checkAns(){
  const ch=curTrack.chapters[curChIdx];
  if(curMode==='concept'){markDone(ch);return;}
  if(curMode==='web'){
    const c=G('web-ed').value.toLowerCase();
    if(ch.ch.ok(c)){markDone(ch);if(isMob())mTab('lesson');}
    else{G('web-st').textContent='⚠️ Not quite';G('web-st').style.color='var(--warn)';}
    return;
  }
  if(curMode==='sql'){
    sBtn('btn-check',true,'⏳');
    try{
      const raw=sqlQuery(G('sql-ed').value);
      if(ch.ch.ok('',raw)){markDone(ch);}
      else{G('sql-st').textContent='⚠️ Not quite';G('sql-st').style.color='var(--warn)';}
    }catch(ex){G('sql-st').textContent='Error';G('sql-st').style.color='var(--err)';}
    sBtn('btn-check',false,'✓ Check');
    return;
  }
  sBtn('btn-check',true,'⏳');
  const{out,err}=await execPy(G('code-ed').value);
  if(err){
    setOut('oerr','❌ Error:\n\n'+err); setSt('● Error','var(--err)');
    sBtn('btn-check',false,'✓ Check'); if(isMob())mTab('code'); return;
  }
  if(ch.ch.ok(out)){
    setOut('owin','🎉 Correct! +'+ch.xp+' XP\n\nYour output:\n'+out); setSt('✓ Passed','var(--ok)');
    markDone(ch);
  } else {
    setOut('oerr','⚠️ Not quite.\n\nYour output:\n'+out+'\n\nTip: Compare carefully with expected above. Press 💡 for a hint!');
    setSt('⚠️ Try again','var(--warn)');
  }
  sBtn('btn-check',false,'✓ Check'); if(isMob())mTab('code');
}

async function getHint(){
  const ch=curTrack.chapters[curChIdx];
  sBtn('btn-hint',true,'⏳');
  if(curMode==='web'){setSt('💡 Check your HTML matches the expected structure','var(--warn)');sBtn('btn-hint',false,'💡 Hint');return;}
  setOut('ohint','💡 Getting hint…'); if(isMob())mTab('code');
  try{
    const code=curMode==='sql'?G('sql-ed').value:G('code-ed').value;
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:200,
        messages:[{role:'user',content:`I'm learning ${curTrack.name}. Challenge: "${ch.ch.title}: ${ch.ch.desc.replace(/<[^>]*>/g,'').replace(/&[^;]+;/g,' ')}"\nMy code:\n${code}\n\nGive a gentle 2-3 sentence hint without solving it.`}]})
    });
    const d=await r.json();
    const hint=(d.content&&d.content[0]&&d.content[0].text)||'Look carefully at expected output, compare line by line.';
    setOut('ohint','💡 Hint:\n\n'+hint);
  }catch{setOut('ohint','💡 Hint: Compare your output line-by-line with the expected. Check spacing, capitalisation and punctuation.');}
  sBtn('btn-hint',false,'💡 Hint');
}

function resetCode(){
  const ch=curTrack.chapters[curChIdx];
  if(curMode==='python'){G('code-ed').value=ch.ch.start;syncPyHL();setOut('od','▶ Run code to see output');setSt('','');}
  else if(curMode==='web'){G('web-ed').value=ch.ch.start;syncWebHL();updatePreview();}
  else if(curMode==='sql'){G('sql-ed').value=ch.ch.start;syncSqlHL();}
}

// ═══════════════ MARK DONE + CELEBRATE ══════════════════════
function markDone(ch){
  const isNew=!done.has(ch.id);
  if(isNew){
    done.add(ch.id); totalXP+=ch.xp; totalDone++;
    updateChips(); updateSbXP(); renderSb(); renderMobChs();
    // Update leaderboard
    if(playerName){
      const idx=leaderboard.findIndex(x=>x.name===playerName);
      if(idx>=0)leaderboard[idx].xp=totalXP; else leaderboard.push({name:playerName,xp:totalXP});
    }
    writeSave();
    spawnXP('+'+ch.xp+' XP ⚡');
    spawnConfetti();
  }
  ['db-d','db-m'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.add('show');});
  ['nb-d','nb-m'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.add('show');});
}

function spawnXP(txt){
  const el=document.createElement('div'); el.className='xp-popup'; el.textContent=txt;
  el.style.cssText=`left:${20+Math.random()*60}%;top:65%;z-index:9999;`;
  document.body.appendChild(el); setTimeout(()=>el.remove(),1400);
}
function spawnConfetti(){
  const cols=['#4d8df5','#c260ff','#f562b8','#f5c518','#3ecf8e','#ff4d6d','#29d7f5'];
  for(let i=0;i<32;i++){
    const el=document.createElement('div'); el.className='cfp';
    el.style.cssText=`left:${Math.random()*100}%;top:-8px;background:${cols[i%cols.length]};
      width:${5+Math.random()*7}px;height:${5+Math.random()*7}px;
      border-radius:${Math.random()>.5?'50%':'2px'};
      animation-duration:${1.2+Math.random()*1.6}s;
      animation-delay:${Math.random()*.35}s;`;
    document.body.appendChild(el); setTimeout(()=>el.remove(),3200);
  }
}

// ═══════════════ WEB PREVIEW ════════════════════════════════
let pvTimer=null;
function updatePreview(){
  clearTimeout(pvTimer);
  pvTimer=setTimeout(()=>{
    const ifr=G('preview');
    try{const d=ifr.contentDocument||ifr.contentWindow.document;d.open();d.write(G('web-ed').value);d.close();}catch{}
    G('web-st').textContent='● Live'; G('web-st').style.color='var(--ok)';
  },260);
}

// ═══════════════ GIT SIMULATOR ══════════════════════════════
const gs={repo:false,branch:'main',staged:[],commits:[],branches:['main']};
function initGit(){
  G('git-inp').addEventListener('keydown',ev=>{if(ev.key==='Enter'){ev.preventDefault();doGit();}});
}
function gp(txt,cls=''){
  const t=G('git-term');
  t.innerHTML+=`<div><span class="${cls}">${e(txt)}</span></div>`;
  t.scrollTop=t.scrollHeight;
}
function doGit(){
  const inp=G('git-inp'),cmd=inp.value.trim(); inp.value='';
  if(!cmd)return;
  const t=G('git-term');
  t.innerHTML+=`<div><span class="git-ps1">$ </span><span class="git-cmd-text">${e(cmd)}</span></div>`;
  const p=cmd.split(' ').filter(Boolean);
  if(p[0]==='clear'){t.innerHTML='';return;}
  if(p[0]==='ls'){gp('README.md  index.html  style.css  main.py');return;}
  if(p[0]==='pwd'){gp('/home/user/my-project');return;}
  if(p[0]==='echo'){gp(p.slice(1).join(' '));return;}
  if(p[0]==='cd'){gp('');return;}
  if(p[0]!=='git'){gp(`command not found: ${p[0]}. Try git commands.`,'git-err');return;}
  const sub=p[1];
  switch(sub){
    case 'init': gs.repo=true; gp('Initialized empty Git repository in ./.git/','git-ok'); break;
    case 'status': gp(`On branch ${gs.branch}`,'git-ok'); gp(gs.staged.length?'Changes staged: '+gs.staged.join(', '):'nothing to commit, working tree clean'); break;
    case 'add': gs.staged=[p[2]||'.']; gp(`Added ${p[2]||'.'}`,'git-ok'); break;
    case 'commit':{
      if(!gs.staged.length){gp('nothing to commit','git-err');break;}
      const m=cmd.match(/-m\s+"?([^"]+)"?/)?.[1]||'Update';
      const h='a'+Math.random().toString(36).slice(2,9);
      gs.commits.push({m,b:gs.branch,h}); gs.staged=[];
      gp(`[${gs.branch} ${h}] ${m}`,'git-ok'); break;}
    case 'log':
      if(!gs.commits.length){gp('No commits yet.','git-err');break;}
      gs.commits.slice().reverse().forEach(c=>{gp(`commit ${c.h} (${c.b})`,'git-info');gp(`    ${c.m}`,'git-ok');});break;
    case 'branch':
      if(p[2]&&p[2]!=='-d'&&!p[2].startsWith('-')){gs.branches.push(p[2]);gp(`Branch '${p[2]}' created`,'git-ok');}
      else if(p[2]==='-d'){gp(`Deleted branch ${p[3]||'?'}`,'git-ok');}
      else gp(gs.branches.map(b=>b===gs.branch?`* ${b}`:` ${b}`).join('\n'));break;
    case 'checkout':
      if(p[2]==='-b'){const nb=p[3]||'new';if(!gs.branches.includes(nb))gs.branches.push(nb);gs.branch=nb;gp(`Switched to new branch '${nb}'`,'git-ok');}
      else if(p[2]){if(gs.branches.includes(p[2])){gs.branch=p[2];gp(`Switched to '${p[2]}'`,'git-ok');}else gp(`Branch '${p[2]}' not found`,'git-err');}
      break;
    case 'merge': gp(`Merged '${p[2]||'?'}' into '${gs.branch}'`,'git-ok');break;
    case 'remote': if(p[2]==='add'){gp(`Remote '${p[3]}' added`,'git-ok');}else if(p[2]==='-v'){gp('origin  https://github.com/user/repo.git','git-info');}break;
    case 'push': gp(`Pushed to origin/${gs.branch} ✓`,'git-ok');break;
    case 'pull': gp('Already up to date.','git-ok');break;
    case 'clone': gp(`Cloning '${(p[2]||'').split('/').pop().replace('.git','')||'repo'}'... done.`,'git-ok');break;
    case 'stash': gp('Stash saved.','git-ok');break;
    case 'diff': gp('(no differences)');break;
    case '--version': gp('git version 2.43.0 (CodeQuest)');break;
    default: gp(`'${sub}' is not a git command. Try: init status add commit log branch checkout push pull clone`,'git-err');
  }
  G('git-term').scrollTop=G('git-term').scrollHeight;
}

// ═══════════════ SIDEBAR / UI ════════════════════════════════
function renderSb(){
  G('sb-list').innerHTML=curTrack.chapters.map((ch,i)=>`
    <div class="sb-item ${i===curChIdx?'active':''} ${done.has(ch.id)?'done':''}" onclick="openChapter(${i})">
      <span class="sb-item-ico">${ch.icon}</span>
      <div class="sb-item-info">
        <div class="sb-item-name">${ch.title}</div>
        <div class="sb-item-xp">+${ch.xp} XP</div>
      </div>
      <span class="sb-star">⭐</span>
    </div>`).join('');
}
function renderMobChs(){
  G('mob-chs-panel').innerHTML=
    `<div style="padding:10px 13px;border-bottom:1px solid var(--b1);font-size:11px;font-weight:700;color:var(--c,var(--py))">${curTrack.icon} ${curTrack.name}</div>`
    +curTrack.chapters.map((ch,i)=>`
      <div class="sb-item ${i===curChIdx?'active':''} ${done.has(ch.id)?'done':''}" onclick="openChapter(${i})">
        <span class="sb-item-ico">${ch.icon}</span>
        <div class="sb-item-info"><div class="sb-item-name">${ch.title}</div><div class="sb-item-xp">+${ch.xp} XP</div></div>
        <span class="sb-star">⭐</span>
      </div>`).join('');
}
function updateSbXP(){
  if(!curTrack)return;
  const txp=curTrack.chapters.filter(c=>done.has(c.id)).reduce((s,c)=>s+c.xp,0);
  const mxp=curTrack.chapters.reduce((s,c)=>s+c.xp,0);
  G('sb-xf').style.cssText=`width:${mxp?txp/mxp*100:0}%;background:${curTrack.color}`;
  G('sb-xn').textContent=txp+' XP'; G('sb-xt').textContent='/'+mxp;
}
function updateChips(){G('xv').textContent=totalXP;G('dv').textContent=totalDone;G('sv').textContent=streak;}

// ═══════════════ EDITOR SETUP ════════════════════════════════
function initEditors(){
  function setup(ta,syncFn,runFn){
    if(!ta)return;
    ta.addEventListener('input',syncFn);
    ta.addEventListener('scroll',()=>{
      // sync highlight scroll
      const hlId=ta.id==='code-ed'?'hl-py':ta.id==='web-ed'?'hl-web':'hl-sql';
      const hl=document.getElementById(hlId);
      if(hl){hl.scrollTop=ta.scrollTop;hl.scrollLeft=ta.scrollLeft;}
    });
    ta.addEventListener('keydown',ev=>{
      if(ev.key==='Tab'){
        ev.preventDefault();
        const s=ta.selectionStart,end=ta.selectionEnd,sp=ta.id==='sql-ed'?'  ':'    ';
        ta.value=ta.value.substring(0,s)+sp+ta.value.substring(end);
        ta.selectionStart=ta.selectionEnd=s+sp.length; syncFn();
      }
      if((ev.ctrlKey||ev.metaKey)&&ev.key==='Enter'){ev.preventDefault();if(runFn)runFn();}
    });
  }
  setup(G('code-ed'),syncPyHL,runCode);
  setup(G('web-ed'),()=>{syncWebHL();updatePreview();},updatePreview);
  setup(G('sql-ed'),syncSqlHL,runSQL);
}

// ═══════════════ MOBILE TABS ════════════════════════════════
function mTab(tab){
  if(!isMob())return;
  mobCurTab=tab;
  const tc=curTrack?curTrack.color:'var(--py)';
  ['lesson','code','chs'].forEach(t=>{
    const el=G('mt-'+t);
    const on=t===tab;
    el.classList.toggle('active',on);
    el.style.color=on?tc:'var(--t3)';
    el.style.borderBottomColor=on?tc:'transparent';
  });
  G('mob-lesson-panel').classList.toggle('active',tab==='lesson');
  G('mob-code-panel').classList.toggle('active',tab==='code');
  G('mob-chs-panel').classList.toggle('active',tab==='chs');
  const ep=G('ed-panel');
  const cp=G('mob-code-panel');
  if(tab==='code'){
    // Move editor INTO the code panel, then use position:absolute inset:0
    // so it fills the container regardless of flex chain issues
    if(ep.parentNode!==cp) cp.appendChild(ep);
    ep.removeAttribute('style');// let CSS handle it via #mob-code-panel.active #ed-panel
    // Force a reflow so the browser recalculates heights
    void ep.offsetHeight;
  } else {
    ep.style.display='none';
  }
}

window.addEventListener('resize',()=>{
  if(!isMob()){
    // Back to desktop: restore ed-panel to its desktop parent
    const ep=G('ed-panel'), ls=G('lessonscreen');
    if(ep.parentNode!==ls) ls.appendChild(ep);
    ep.removeAttribute('style');
    ['mob-lesson-panel','mob-code-panel','mob-chs-panel'].forEach(id=>G(id).classList.remove('active'));
  } else if(curTrack){
    // Re-apply mobile tab state after orientation change
    mTab(mobCurTab);
  }
});

// ═══════════════ HELPERS ════════════════════════════════════
function G(id){return document.getElementById(id);}
function e(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function setOut(cls,txt){G('out-body').innerHTML=`<span class="${cls}">${e(txt)}</span>`;}
function setSt(txt,col){const el=G('out-st');el.textContent=txt;el.style.color=col;}
function sBtn(id,dis,lbl){const b=G(id);if(!b)return;b.disabled=dis;if(lbl)b.textContent=lbl;}
function isMob(){return window.innerWidth<768;}

document.addEventListener('DOMContentLoaded',()=>{
  if(isMob()){
    G('ed-panel').style.display='none';
    // Listen for orientation changes
    screen.orientation && screen.orientation.addEventListener('change',()=>{
      setTimeout(()=>{ if(curTrack) mTab(mobCurTab); }, 100);
    });
  }
});

// ═══════════════════════════════════════════════════════════════
//  DRAG-TO-RESIZE SPLITTERS
// ═══════════════════════════════════════════════════════════════
function initDrags(){
  // Horizontal drag: between code editor area and output panel
  makeDragH('drag-py',  'py-ed-wrap',  'py-out-wrap',  'py-mode',  28, 28);
  makeDragH('drag-sql', 'sql-ed-wrap', 'sql-out-wrap', 'sql-mode', 28, 28);
  makeDragH('drag-web', 'web-ed-wrap-outer', 'web-preview-wrap', 'web-inner', 28, 28);
  // Vertical drag: between lesson pane and editor panel (desktop only)
  makeDragV('drag-v', 'lesson-pane', 'ed-panel', 'lessonscreen', 120, 120);
}

/**
 * makeDragH — draggable horizontal divider
 * @param {string} handleId   - the .drag-h element
 * @param {string} topId      - element above the handle (gets flex-basis changed)
 * @param {string} botId      - element below the handle
 * @param {string} containerId- parent container (for total height)
 * @param {number} minTop     - min px for top section
 * @param {number} minBot     - min px for bottom section
 */
function makeDragH(handleId, topId, botId, containerId, minTop, minBot){
  const handle = G(handleId);
  const topEl  = G(topId);
  const botEl  = G(botId);
  if(!handle||!topEl||!botEl) return;

  let startY=0, startTopH=0, startBotH=0, dragging=false;

  function onStart(e){
    e.preventDefault();
    dragging=true;
    handle.classList.add('dragging');
    document.body.style.cursor='row-resize';
    document.body.style.userSelect='none';
    startY  = e.touches ? e.touches[0].clientY : e.clientY;
    startTopH = topEl.getBoundingClientRect().height;
    startBotH = botEl.getBoundingClientRect().height;
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup',   onEnd);
    window.addEventListener('touchmove', onMove, {passive:false});
    window.addEventListener('touchend',  onEnd);
  }
  function onMove(e){
    if(!dragging) return;
    e.preventDefault();
    const y = e.touches ? e.touches[0].clientY : e.clientY;
    const dy = y - startY;
    let newTop = startTopH + dy;
    let newBot = startBotH - dy;
    const total = startTopH + startBotH;
    newTop = Math.max(minTop, Math.min(newTop, total - minBot));
    newBot = total - newTop;
    // Use flex-basis + flex-shrink:0 for precise control
    topEl.style.flex = 'none';
    topEl.style.height = newTop + 'px';
    botEl.style.flex = 'none';
    botEl.style.height = newBot + 'px';
    // Re-sync highlight layers
    if(topId === 'py-ed-wrap')  syncPyHL();
    if(topId === 'sql-ed-wrap') syncSqlHL();
  }
  function onEnd(){
    if(!dragging) return;
    dragging=false;
    handle.classList.remove('dragging');
    document.body.style.cursor='';
    document.body.style.userSelect='';
    window.removeEventListener('mousemove', onMove);
    window.removeEventListener('mouseup',   onEnd);
    window.removeEventListener('touchmove', onMove);
    window.removeEventListener('touchend',  onEnd);
  }
  handle.addEventListener('mousedown',  onStart);
  handle.addEventListener('touchstart', onStart, {passive:false});
}

/**
 * makeDragV — draggable vertical divider (desktop only)
 */
function makeDragV(handleId, leftId, rightId, containerId, minLeft, minRight){
  const handle = G(handleId);
  const leftEl = G(leftId);
  const rightEl= G(rightId);
  if(!handle||!leftEl||!rightEl) return;

  let startX=0, startLW=0, startRW=0, dragging=false;

  function onStart(e){
    if(isMob()) return;
    e.preventDefault();
    dragging=true;
    handle.classList.add('dragging');
    document.body.style.cursor='col-resize';
    document.body.style.userSelect='none';
    startX  = e.clientX;
    startLW = leftEl.getBoundingClientRect().width;
    startRW = rightEl.getBoundingClientRect().width;
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup',   onEnd);
  }
  function onMove(e){
    if(!dragging) return;
    const dx = e.clientX - startX;
    let newL = startLW + dx;
    let newR = startRW - dx;
    const total = startLW + startRW;
    newL = Math.max(minLeft,  Math.min(newL, total - minRight));
    newR = total - newL;
    leftEl.style.flex = 'none';
    leftEl.style.width = newL + 'px';
    rightEl.style.flex = '1';
    rightEl.style.width = '';
  }
  function onEnd(){
    if(!dragging) return;
    dragging=false;
    handle.classList.remove('dragging');
    document.body.style.cursor='';
    document.body.style.userSelect='';
    window.removeEventListener('mousemove', onMove);
    window.removeEventListener('mouseup',   onEnd);
  }
  handle.addEventListener('mousedown', onStart);

  // Double-click resets to default
  handle.addEventListener('dblclick', ()=>{
    leftEl.style.flex = '';
    leftEl.style.width = '';
    rightEl.style.flex = '1';
    rightEl.style.width = '';
  });
}

// Web mode inner container needs an id for drag
document.addEventListener('DOMContentLoaded', ()=>{
  // Give web mode inner split div an id so drag can find it
  const webInner = document.querySelector('#web-mode > div');
  if(webInner){ webInner.id = 'web-inner'; }
  const webEdWrap = document.querySelector('#web-mode .web-ed-wrap');
  if(webEdWrap){ webEdWrap.id = 'web-ed-wrap-outer'; }
  initDrags();
});

</script>
</body>
</html>
